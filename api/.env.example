# ══════════════════════════════════════════════════════
# Forge3D – Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.
# ══════════════════════════════════════════════════════

# ── Flask ──────────────────────────────────────────────
FLASK_ENV=development
PORT=5000

# ── JWT ────────────────────────────────────────────────
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change_me_to_a_strong_random_secret
JWT_EXPIRY_HOURS=24

# ── Supabase / PostgreSQL ──────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DB
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres?sslmode=require

# Supabase project URL (from Dashboard → Settings → API)
SUPABASE_URL=https://[YOUR-PROJECT-REF].supabase.co

# Use the SERVICE ROLE key (not the anon key) for signed upload URLs
SUPABASE_SERVICE_KEY=eyJ...your-service-role-key...

# Name of the Supabase Storage bucket for 3D assets
SUPABASE_BUCKET=forge3d-assets

# ── CORS ───────────────────────────────────────────────
# Comma-separated list of allowed origins (use * for dev)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,https://your-frontend.vercel.app
